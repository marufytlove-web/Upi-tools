# Copy this file to .env.local and fill in real values.
# Never commit real secrets, mnemonics, database URLs, proxy credentials, or user sessions.

# App
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3001"
APP_URL="http://127.0.0.1:3001"
JWT_SECRET="replace-with-a-long-random-secret"
SESSION_TOKEN_ENCRYPTION_KEY="replace-with-a-different-long-random-secret"
UPLOAD_DIR=""
SITE_MAINTENANCE_PAGE="0"
ADMIN_PASSWORD="change-this-admin-password"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gpt_upi?schema=public"
LOCAL_TEST_DATABASE_URL=""
LOCAL_TEST_SCHEMA="gpt_upi_local_test"

# Telegram bot login / notifications
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_ADMIN_ID=""
TELEGRAM_ADMIN_USERNAME=""
NEXT_PUBLIC_TG_INVITE_URL="https://t.me/your_group"
NEXT_PUBLIC_SCANNER_TG_GROUP_URL="https://t.me/your_scanner_group"
NEXT_PUBLIC_SCANNER_APPLY_URL="https://t.me/your_admin"
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""

# Public user premium defaults (comma-separated Telegram IDs/usernames; optional)
PREMIUM_TELEGRAM_IDS=""
PREMIUM_TELEGRAM_USERNAMES=""

# Extraction runtime
# external = web process does not run extraction jobs; run `npm run upi:worker` separately.
# inline = web process runs extraction jobs in dev/single-process deployments.
UPI_EXTRACT_RUNNER="inline"
UPI_EXTRACT_WORKER_INTERVAL_MS="1000"
UPI_EXTRACT_PAUSED="0"
PUBLIC_UPI_EXTRACT_PAUSED="0"
PREMIUM_UPI_EXTRACT_PAUSED="0"
PUBLIC_UPI_EXTRACT_CONCURRENCY="10"
PREMIUM_UPI_EXTRACT_CONCURRENCY="20"
UPI_EXTRACT_CONCURRENCY="10"
ENABLE_EXTRACT_METHOD_SELECTION="0"
NEXT_PUBLIC_ENABLE_EXTRACT_METHOD_SELECTION="0"

# External QR generation API. Prefer PlusPay for hosted deployments.
PLUSPAY_API_KEY=""
PLUSPAY_API_KEYS=""
PLUSPAY_API_BASE="https://api.pluspaybot.dpdns.org"
PLUSPAY_API_DISABLED="0"
LINHTD_UPI_API_KEY=""
LINHTD_UPI_API_BASE="https://upiapi.linhtd.com"
LINHTD_UPI_API_DISABLED="1"

# Upstream proxy pools (comma-separated; supports http://, https://, socks5://)
UPSTREAM_PROXY=""
UPSTREAM_PROXY_LIST=""
UPI_PROXY_LIST=""
PREMIUM_UPSTREAM_PROXY=""
PREMIUM_UPSTREAM_PROXY_LIST=""
PREMIUM_UPI_PROXY_LIST=""
UPSTREAM_PROXY_EXPECTED_COUNTRY=""

# Checkout/payment experiment knobs; keep blank unless you know the exact values needed.
CHATGPT_UPI_COUNTRY="IN"
CHATGPT_UPI_CURRENCY="inr"
CHATGPT_UPI_PROMO_CAMPAIGN_ID=""
CHATGPT_UPI_APPROVAL_ATTEMPTS=""
CHATGPT_UPI_APPROVAL_PARALLELISM=""
CHATGPT_TIMEZONE_OFFSET_MIN=""
CHATGPT_IDEAL_COUNTRY="NL"
CHATGPT_IDEAL_CURRENCY="eur"
CHATGPT_IDEAL_PROMO_CAMPAIGN_ID=""
CHATGPT_IDEAL_APPROVAL_ATTEMPTS=""
CHATGPT_IDEAL_APPROVAL_PARALLELISM=""
CHATGPT_IDEAL_BANK=""

# BSC / BEP20 USDT deposit watcher
BSC_RPC_URL="https://bsc-rpc.publicnode.com"
BSC_USDT_CONTRACT="0x55d398326f99059fF775485246999027B3197955"
BSC_DEPOSIT_MNEMONIC=""
BSC_DEPOSIT_CONFIRMATIONS="20"
BSC_DEPOSIT_WATCHER_DISABLED="0"
BSC_DEPOSIT_POLL_MS="15000"
BSC_DEPOSIT_INITIAL_LOOKBACK_BLOCKS="5000"
BSC_DEPOSIT_MAX_BACKFILL_BLOCKS="20000"
BSC_DEPOSIT_SCAN_RANGE_BLOCKS="2000"
BSC_DEPOSIT_MIN_SCAN_RANGE_BLOCKS="200"
BSC_DEPOSIT_ADDRESS_TOPIC_CHUNK="80"

# Optional Redis cache. Leave blank to use in-process short cache only.
REDIS_URL=""
REDIS_HOST=""
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_KEY_PREFIX="gpt_upi:"
